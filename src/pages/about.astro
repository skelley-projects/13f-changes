  h1 {
    font-size: 1.5rem;
    color: var(--fg);
    margin: 0 0 16px;
  }
  h2 {
    font-size: 1.05rem;
    margin-top: 28px;
    color: var(--accent);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  p, li { color: var(--fg); }
  ul { padding-left: 20px; }
  li { margin-bottom: 4px; }
  code {
    font-family: var(--font-mono);
    background: var(--bg-elev);
    padding: 1px 4px;
    border-radius: 3px;
    font-size: 0.85em;
    color: var(--fg);
  }
  em { color: var(--fg-muted); font-style: italic; }
  strong { color: var(--fg); }
</style>
