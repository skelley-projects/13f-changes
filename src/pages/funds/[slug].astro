---
import Layout from '../../components/Layout.astro';
import FundHeader from '../../components/FundHeader.astro';
import ChangeHero from '../../components/ChangeHero.astro';
import SectorDeltaBars from '../../components/SectorDeltaBars.astro';
import CapitalFlowBars from '../../components/CapitalFlowBars.astro';
import ActivityTable from '../../components/ActivityTable.astro';
import MovementTable from '../../components/MovementTable.astro';
import MovementHighlights from '../../components/MovementHighlights.astro';
import PerformanceTable from '../../components/PerformanceTable.astro';
import HoldingsTable from '../../components/HoldingsTable.astro';
import DataFreshness from '../../components/DataFreshness.astro';
import DryPowderPanel from '../../components/DryPowderPanel.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import {
  loadFunds, loadFundQuarters, loadFiling, loadDiff, loadSecurities, loadFundTags, loadPriceSnapshot,
  loadFundDryPowder,
} from '../../lib/data';

export async function getStaticPaths() {
  const funds = loadFunds();
  return funds.map(fund => ({ params: { slug: fund.slug }, props: { fund } }));
}

const { slug } = Astro.params;
const { fund } = Astro.props;

const quartersFile = loadFundQuarters(slug!);
const currentQuarter = quartersFile.quarters[0];
const priorQuarter = quartersFile.quarters[1] ?? null;

if (!currentQuarter) {
  return Astro.redirect('/');
}

const filing = loadFiling(slug!, currentQuarter.period);
const diff = loadDiff(slug!, currentQuarter.period);
const securities = loadSecurities();
const tagsFile = loadFundTags(slug!);
const prices = loadPriceSnapshot();
const dryPowder = loadFundDryPowder(slug!);

if (!filing || !diff) {
  throw new Error(`Missing filing or diff for ${slug} ${currentQuarter.period}`);
}

const priorFiling = priorQuarter ? loadFiling(slug!, priorQuarter.period) : null;
const positionKey = (p: { cusip: string; title_of_class: string; put_call: string | null }) =>
  `${p.cusip}|${p.title_of_class}|${p.put_call ?? ''}`;
const priorPositions = new Map((priorFiling?.positions ?? []).map(p => [positionKey(p), p]));
const unchangedKeys = new Set<string>();
for (const p of filing.positions) {
  const priorPosition = priorPositions.get(positionKey(p));
  if (priorPosition && priorPosition.shares === p.shares) unchangedKeys.add(positionKey(p));
}
---
<Layout title={`${fund.name} — 13f-changes`} width="default">
  <nav class="topnav"><a href="/">← All funds</a></nav>
  <FundHeader fund={fund} quarter={currentQuarter} priorPeriod={priorQuarter?.period ?? null} />
  <DataFreshness quarter={currentQuarter} prices={prices} />
  {dryPowder && <DryPowderPanel dryPowder={dryPowder} reported13fValue={currentQuarter.total_value} />}
  <ChangeHero diff={diff} summary={currentQuarter.summary} />

  {diff.prior_period && (
    <section class="analysis-section">
      <div class="analysis-heading">
        <div class="analysis-kicker">Exposure view</div>
        <p>Quarter-end weights. Market performance can move these bars even when shares are unchanged.</p>
      </div>
      <div class="breakdown-grid">
        <SectorDeltaBars title="Sector exposure shifts" breakdown={diff.sector_breakdown} />
        {diff.theme_breakdown && (
          <SectorDeltaBars title="Theme exposure shifts" breakdown={diff.theme_breakdown} linkLabels />
        )}
      </div>
    </section>
  )}

  {diff.granular_breakdown && (
    <section class="granular-section">
      <div class="coverage-note">
        Granular exposure coverage: {(diff.granular_coverage_pct ?? 0).toFixed(1)}% of AUM
      </div>
      <SectorDeltaBars title="Granular exposure shifts" breakdown={diff.granular_breakdown} linkLabels />
    </section>
  )}

  {diff.theme_activity_breakdown && (
    <section class="activity-section">
      <div class="analysis-heading">
        <div class="analysis-kicker">Activity view</div>
        <p>Estimated buy/sell decisions from active share-count changes. Unchanged winners are excluded.</p>
      </div>
      <div class="activity-grid">
        <CapitalFlowBars
          title="Theme activity"
          breakdown={diff.theme_activity_breakdown}
          note="Estimated capital bought/sold from new, closed, increased, decreased, and buy/sell activity rows. Unchanged positions are excluded so market gains do not drive this view. Multi-theme positions count once in each assigned theme."
          totalsLabel="theme-tagged"
          linkLabels
        />
        {diff.granular_activity_breakdown && (
          <CapitalFlowBars
            title="Granular activity"
            breakdown={diff.granular_activity_breakdown}
            note="Grouped by granular sub-tags using the same estimated buy/sell methodology."
            totalsLabel="granular-tagged"
            linkLabels
          />
        )}
      </div>
    </section>
  )}

  {diff.prior_period && (
    <section class="movements">
      <div class="section-label">Position movements</div>
      <MovementHighlights diff={diff} />
      <p class="pricing-note">
        Price = reported fair value divided by reported shares at quarter-end. Since q-end shows price change since the end of the reported quarter; ordinary-share rows also include estimated value move, while shaded option rows show underlying stock move only and sort after ordinary equity.
      </p>
      <ActivityTable rows={diff.movements.activity ?? []} taxonomy={tagsFile.taxonomy} prices={prices} currentPeriod={diff.current_period} />
      <MovementTable status="NEW" rows={diff.movements.new} taxonomy={tagsFile.taxonomy} prices={prices} currentPeriod={diff.current_period} />
      <MovementTable status="INCREASED" rows={diff.movements.increased} taxonomy={tagsFile.taxonomy} prices={prices} currentPeriod={diff.current_period} />
      <MovementTable status="DECREASED" rows={diff.movements.decreased} taxonomy={tagsFile.taxonomy} prices={prices} currentPeriod={diff.current_period} />
      <MovementTable status="CLOSED" rows={diff.movements.closed} taxonomy={tagsFile.taxonomy} prices={prices} currentPeriod={diff.current_period} />
    </section>
  )}

  <PerformanceTable filing={filing} securities={securities} prices={prices} />

  <HoldingsTable
    filing={filing}
    securities={securities}
    unchangedOnly={diff.prior_period !== null}
    unchangedKeys={unchangedKeys}
    taxonomy={tagsFile.taxonomy}
    assignments={tagsFile.assignments}
  />

  <footer class="methodology">
    <strong>Methodology:</strong> Data from SEC 13F-HR filings. Prices are quarter-end filing marks and latest Yahoo Finance snapshots. Themes assigned editorially per-fund. <a href="/about">More →</a>
  </footer>

  <ContactCTA />
</Layout>

<style>
  .topnav {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.45px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .topnav a { color: var(--fg-muted); }
  .topnav a:hover { color: var(--accent); text-decoration: none; }
  .breakdown-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
  .activity-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .analysis-section { margin-bottom: 24px; }
  .analysis-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 18px;
    margin: 0 0 10px;
  }
  .analysis-kicker {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.75px;
    white-space: nowrap;
  }
  .analysis-heading p {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.76rem;
    line-height: 1.4;
    text-align: right;
  }
  .section-label {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--accent);
    letter-spacing: 0;
    margin: 28px 0 12px;
  }
  .movements { margin-bottom: 24px; }
  .pricing-note {
    max-width: 760px;
    margin: -4px 0 14px;
    color: var(--fg-muted);
    font-size: 0.76rem;
    line-height: 1.5;
  }
  .granular-section {
    margin-top: 28px;
    margin-bottom: 24px;
  }
  .activity-section {
    margin-top: 28px;
    margin-bottom: 24px;
  }
  .coverage-note {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.75px;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .methodology {
    font-size: 0.75rem;
    color: var(--fg-muted);
    line-height: 1.5;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    margin-top: 32px;
  }
  @media (max-width: 700px) {
    .breakdown-grid { grid-template-columns: 1fr; }
    .activity-grid { grid-template-columns: 1fr; }
    .analysis-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
    }
    .analysis-heading p { text-align: left; }
  }
</style>
