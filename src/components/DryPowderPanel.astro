---
import { formatPct, formatUSD } from '../lib/format';
import type { DryPowderFile } from '../../scripts/types';

interface Props {
  dryPowder: DryPowderFile;
  reported13fValue: number;
}

const { dryPowder, reported13fValue } = Astro.props;
const current = dryPowder.values.current;
const prior = dryPowder.values.prior;
const delta = current.total_dry_powder - prior.total_dry_powder;
const deltaPct = prior.total_dry_powder > 0 ? (delta / prior.total_dry_powder) * 100 : 0;
const ratioTo13f = reported13fValue > 0 ? (current.total_dry_powder / reported13fValue) * 100 : 0;
const history = (dryPowder.history?.length
  ? dryPowder.history
  : [
      { ...prior, filing_date: dryPowder.source_filing.filing_date, accession: dryPowder.source_filing.accession, form: dryPowder.source_filing.form, url: dryPowder.source_filing.url },
      { ...current, filing_date: dryPowder.source_filing.filing_date, accession: dryPowder.source_filing.accession, form: dryPowder.source_filing.form, url: dryPowder.source_filing.url },
    ]).slice().sort((a, b) => a.period_ending.localeCompare(b.period_ending));
const latestHistory = history[history.length - 1];
const maxDryPowder = Math.max(...history.map(row => row.total_dry_powder), 1);
const chartMax = Math.ceil(maxDryPowder / 50_000_000_000) * 50_000_000_000;
const ratios = history
  .map(row => row.dry_powder_to_equities)
  .filter((value): value is number => typeof value === 'number' && Number.isFinite(value));
const ratioMax = Math.max(1.5, Math.ceil((Math.max(...ratios, 0) + 0.1) * 4) / 4);
const chart = { width: 900, height: 318, left: 56, right: 58, top: 18, bottom: 46 };
const plotWidth = chart.width - chart.left - chart.right;
const plotHeight = chart.height - chart.top - chart.bottom;
const step = history.length > 1 ? plotWidth / (history.length - 1) : plotWidth;
const barWidth = Math.min(24, Math.max(8, plotWidth / Math.max(history.length, 1) * 0.42));
const yTicks = [0, chartMax / 2, chartMax];
const ratioTicks = [0, ratioMax / 2, ratioMax];

function barParts(row: typeof history[number], index: number) {
  const x = chart.left + (history.length > 1 ? index * step : plotWidth / 2) - barWidth / 2;
  const cashHeight = (row.cash_and_equivalents / chartMax) * plotHeight;
  const tbillHeight = (row.short_term_treasury_bills / chartMax) * plotHeight;
  const totalHeight = cashHeight + tbillHeight;
  const baseY = chart.top + plotHeight;
  return {
    x,
    cashY: baseY - cashHeight,
    cashHeight,
    tbillY: baseY - totalHeight,
    tbillHeight,
    totalY: baseY - totalHeight,
  };
}

function yFor(value: number): number {
  return chart.top + plotHeight - (value / chartMax) * plotHeight;
}

function yForRatio(value: number): number {
  return chart.top + plotHeight - (value / ratioMax) * plotHeight;
}

function xForIndex(index: number): number {
  return chart.left + (history.length > 1 ? index * step : plotWidth / 2);
}

const ratioPoints = history
  .map((row, index) => (
    row.dry_powder_to_equities === null || row.dry_powder_to_equities === undefined
      ? null
      : `${xForIndex(index)},${yForRatio(row.dry_powder_to_equities)}`
  ))
  .filter(Boolean)
  .join(' ');

function periodLabel(value: string): string {
  const [year, month] = value.split('-');
  const quarter = month === '03' ? 'Q1' : month === '06' ? 'Q2' : month === '09' ? 'Q3' : 'Q4';
  return `${quarter} '${year.slice(2)}`;
}

function shouldShowXLabel(index: number): boolean {
  if (history.length <= 8) return true;
  return index === 0 || index === history.length - 1 || index % Math.ceil(history.length / 5) === 0;
}

function formatRatio(value: number | null | undefined): string {
  return value === null || value === undefined ? '-' : `${value.toFixed(2)}x`;
}

function signedUSD(value: number): string {
  return `${value >= 0 ? '+' : '-'}${formatUSD(Math.abs(value))}`;
}

function shortDate(value: string): string {
  return new Date(`${value}T00:00:00.000Z`).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---

<section class="dry-powder">
  <div class="panel-heading">
    <div>
      <div class="kicker">Berkshire dry powder</div>
      <h2>{formatUSD(current.total_dry_powder)}</h2>
      <p>
        Cash, cash equivalents, and short-term U.S. Treasury bills from Berkshire's company filing.
        These balances are not visible in Form 13F.
      </p>
    </div>
    <a href={dryPowder.source_filing.url} target="_blank" rel="noopener">
      SEC {dryPowder.source_filing.form} ->
    </a>
  </div>

  <div class="metrics">
    <div>
      <span>Cash & equivalents</span>
      <strong>{formatUSD(current.cash_and_equivalents)}</strong>
    </div>
    <div>
      <span>Short-term T-bills</span>
      <strong>{formatUSD(current.short_term_treasury_bills)}</strong>
    </div>
    <div>
      <span>Vs prior filing</span>
      <strong class={delta >= 0 ? 'pos' : 'neg'}>{signedUSD(delta)} ({deltaPct >= 0 ? '+' : ''}{formatPct(deltaPct)})</strong>
    </div>
    <div>
      <span>Dry powder / 13F value</span>
      <strong>{formatPct(ratioTo13f)}</strong>
    </div>
    <div>
      <span>Dry powder / equities</span>
      <strong>{formatRatio(latestHistory?.dry_powder_to_equities)}</strong>
    </div>
  </div>

  <div class="history-chart" aria-label="Berkshire dry powder over time">
    <div class="chart-heading">
      <div>
        <span>Dry powder history</span>
        <strong>{history.length} disclosed periods</strong>
      </div>
      <div class="legend">
        <span><i class="swatch tbill"></i>Short-term T-bills</span>
        <span><i class="swatch cash"></i>Cash</span>
        <span><i class="swatch ratio"></i>Dry powder / equities</span>
      </div>
    </div>
    <svg viewBox={`0 0 ${chart.width} ${chart.height}`} role="img">
      <title>Berkshire cash and short-term Treasury bills over time</title>
      {yTicks.map((tick) => (
        <g>
          <line class="grid" x1={chart.left} x2={chart.width - chart.right} y1={yFor(tick)} y2={yFor(tick)} />
          <text class="axis y-axis" x={chart.left - 10} y={yFor(tick) + 4}>{formatUSD(tick)}</text>
        </g>
      ))}
      {ratioTicks.map((tick) => (
        <text class="axis ratio-axis" x={chart.width - chart.right + 10} y={yForRatio(tick) + 4}>{formatRatio(tick)}</text>
      ))}
      {history.map((row, index) => {
        const parts = barParts(row, index);
        return (
          <g>
            <a href={row.url} target="_blank" rel="noopener">
              <title>{periodLabel(row.period_ending)}: {formatUSD(row.total_dry_powder)} total dry powder; equities {row.equity_securities ? formatUSD(row.equity_securities) : '-'}; ratio {formatRatio(row.dry_powder_to_equities)}</title>
              <rect class="bar tbill-bar" x={parts.x} y={parts.tbillY} width={barWidth} height={parts.tbillHeight} rx="2" />
              <rect class="bar cash-bar" x={parts.x} y={parts.cashY} width={barWidth} height={parts.cashHeight} rx="2" />
            </a>
            {shouldShowXLabel(index) && (
              <text class="axis x-axis" x={parts.x + barWidth / 2} y={chart.height - 20}>{periodLabel(row.period_ending)}</text>
            )}
          </g>
        );
      })}
      {ratioPoints && <polyline class="ratio-line" points={ratioPoints} fill="none" />}
      {history.map((row, index) => row.dry_powder_to_equities !== null && row.dry_powder_to_equities !== undefined && (
        <a href={row.url} target="_blank" rel="noopener">
          <circle class="ratio-dot" cx={xForIndex(index)} cy={yForRatio(row.dry_powder_to_equities)} r="3.4">
            <title>{periodLabel(row.period_ending)} dry powder / equities: {formatRatio(row.dry_powder_to_equities)}</title>
          </circle>
        </a>
      ))}
    </svg>
  </div>

  <p class="source-note">
    Source: {dryPowder.context} Current period {shortDate(current.period_ending)}; prior period {shortDate(prior.period_ending)}.
    Berkshire gets this extra module because it is a public company with balance-sheet filings; private hedge-fund 13Fs do not disclose comparable cash balances.
    {dryPowder.update_policy?.automation}
  </p>
</section>

<style>
  .dry-powder {
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    background: var(--bg-elev);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.14);
    margin: 0 0 24px;
    padding: 18px;
  }
  .panel-heading {
    display: flex;
    gap: 18px;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: 1px solid var(--border);
    padding-bottom: 14px;
  }
  .kicker {
    color: var(--accent);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.75px;
    text-transform: uppercase;
  }
  h2 {
    color: var(--fg);
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 500;
    line-height: 1;
    margin: 4px 0 8px;
  }
  p {
    color: var(--fg-muted);
    font-size: 0.82rem;
    line-height: 1.5;
    margin: 0;
    max-width: 680px;
  }
  .panel-heading a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    white-space: nowrap;
  }
  .metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    padding-top: 14px;
  }
  .metrics div {
    border-top: 1px solid var(--border);
    padding-top: 9px;
  }
  .metrics span {
    color: var(--fg-muted);
    display: block;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.7px;
    margin-bottom: 3px;
    text-transform: uppercase;
  }
  .metrics strong {
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.98rem;
  }
  .metrics .pos { color: var(--pos); }
  .metrics .neg { color: var(--neg); }
  .source-note {
    border-top: 1px solid var(--border);
    margin-top: 14px;
    padding-top: 12px;
    font-size: 0.74rem;
  }
  .history-chart {
    border-top: 1px solid var(--border);
    margin-top: 16px;
    padding-top: 14px;
  }
  .chart-heading {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .chart-heading span,
  .legend span {
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.7px;
    text-transform: uppercase;
  }
  .chart-heading strong {
    color: var(--fg);
    display: block;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 500;
    margin-top: 2px;
  }
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: flex-end;
  }
  .legend span {
    align-items: center;
    display: inline-flex;
    gap: 6px;
  }
  .swatch {
    border-radius: 2px;
    display: inline-block;
    height: 8px;
    width: 18px;
  }
  .swatch.tbill { background: var(--accent); }
  .swatch.cash { background: var(--pos); }
  .swatch.ratio { background: var(--fg); }
  svg {
    display: block;
    height: auto;
    width: 100%;
  }
  .grid {
    stroke: var(--border);
    stroke-width: 1;
  }
  .bar {
    transition: opacity 160ms ease;
  }
  a:hover .bar {
    opacity: 0.78;
  }
  .tbill-bar { fill: var(--accent); }
  .cash-bar { fill: var(--pos); }
  .axis {
    fill: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: 11px;
  }
  .y-axis { text-anchor: end; }
  .ratio-axis { text-anchor: start; }
  .x-axis { text-anchor: middle; }
  .ratio-line {
    stroke: var(--fg);
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }
  .ratio-dot {
    fill: var(--bg-elev);
    stroke: var(--fg);
    stroke-width: 2;
    transition: fill 160ms ease;
  }
  a:hover .ratio-dot { fill: var(--fg); }

  @media (max-width: 760px) {
    .panel-heading {
      flex-direction: column;
      gap: 8px;
    }
    .metrics {
      grid-template-columns: 1fr 1fr;
    }
    .chart-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }
    .legend { justify-content: flex-start; }
  }

  @media (max-width: 480px) {
    .metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
