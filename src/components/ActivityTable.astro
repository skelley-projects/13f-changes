---
import { formatUSD, formatPrice } from '../lib/format';
import {
  estimateLatestGainForRows,
  priceRangeFor,
  priceUnsupportedLabel,
  weightedImpliedPositionPrice,
} from '../lib/implied-price';
import ThemeLinks from './ThemeLinks.astro';
import { themeLabelsFor } from '../lib/theme';
import type { MovementActivity, PriceSnapshotFile, TaxonomyEntry } from '../../scripts/types';

interface Props {
  rows: MovementActivity[];
  taxonomy: TaxonomyEntry[];
  prices: PriceSnapshotFile | null;
  currentPeriod: string;
}
const { rows, taxonomy, prices, currentPeriod } = Astro.props;
function isOptionActivity(row: MovementActivity): boolean {
  return [...row.bought, ...row.sold].some(r => r.put_call !== null);
}

const displayRows = [...rows].sort((a, b) => Number(isOptionActivity(a)) - Number(isOptionActivity(b)));

const totalBought = rows.reduce((s, r) => s + r.current_value, 0);
const totalSold = rows.reduce((s, r) => s + r.prior_value, 0);
const net = totalBought - totalSold;

function priceParts(row: MovementActivity): { buy: string; sell: string } {
  const boughtPrice = weightedImpliedPositionPrice(row.bought, 'current');
  const soldRange = row.sold[0] ? priceRangeFor(row.sold[0], currentPeriod, prices) : null;
  const soldPrice = soldRange
    ? `${formatPrice(soldRange.low)}-${formatPrice(soldRange.high)}`
    : weightedImpliedPositionPrice(row.sold, 'prior');
  const soldUnsupported = row.sold.map(priceUnsupportedLabel).find(Boolean);
  return {
    buy: boughtPrice === null ? '-' : formatPrice(boughtPrice),
    sell: typeof soldPrice === 'number'
      ? formatPrice(soldPrice)
      : soldPrice ?? soldUnsupported ?? '-',
  };
}

function signedUSD(value: number): string {
  return `${value >= 0 ? '+' : '-'}${formatUSD(Math.abs(value))}`;
}

function csvCell(value: string | number | null | undefined): string {
  const text = value === null || value === undefined ? '' : String(value);
  return `"${text.replace(/"/g, '""')}"`;
}

function gainParts(row: MovementActivity): { text: string; tone: 'pos' | 'neg' | 'muted' } {
  const gain = estimateLatestGainForRows(row.bought, prices);
  if (!gain) return { text: '-', tone: 'muted' };
  return {
    text: `${signedUSD(gain.value)} (${gain.pct >= 0 ? '+' : ''}${gain.pct.toFixed(1)}%)`,
    tone: gain.value >= 0 ? 'pos' : 'neg',
  };
}

const csvRows = [
  ['Ticker', 'Name', 'Sector', 'Industry', 'Themes', 'Granular', 'Bought price', 'Bought value', 'Sold price', 'Sold value', 'Since q-end', 'Net'],
  ...displayRows.map((row) => {
    const prices = priceParts(row);
    const gain = gainParts(row);
    return [
      row.ticker ?? row.key,
      row.name,
      row.sector,
      row.industry,
      themeLabelsFor(row.tags, taxonomy).join(' | '),
      themeLabelsFor(row.tags, taxonomy, true).join(' | '),
      prices.buy,
      row.current_value,
      prices.sell,
      row.prior_value,
      gain.text,
      row.net_delta_value,
    ];
  }),
];
const csvText = csvRows.map(row => row.map(csvCell).join(',')).join('\n');
const csvFilename = `${currentPeriod}-buy-sell-activity.csv`;
---
{rows.length === 0 ? null : (
  <section class="movement movement-activity">
    <header>
      <span class="status-label">BUY / SELL ACTIVITY ({rows.length})</span>
      <span class="header-actions">
        <button type="button" class="csv-button" data-filename={csvFilename} data-csv={csvText}>CSV</button>
        <span class="net">
          bought {formatUSD(totalBought)} / sold {formatUSD(totalSold)}
          {' '}(<span class={net >= 0 ? 'pos' : 'neg'}>{net >= 0 ? '+' : '-'}{formatUSD(Math.abs(net))}</span> net)
        </span>
      </span>
    </header>
    <table>
      <thead>
        <tr>
          <th>Ticker</th>
          <th>Name</th>
          <th>Sector</th>
          <th>Themes</th>
          <th class="granular">Granular</th>
          <th>Price* / value</th>
          <th class="num gain-head">Since q-end*</th>
          <th class="num">Net</th>
        </tr>
      </thead>
      <tbody>
        {displayRows.map((r) => {
          const broad = themeLabelsFor(r.tags, taxonomy);
          const granular = themeLabelsFor(r.tags, taxonomy, true);
          const prices = priceParts(r);
          const gain = gainParts(r);
          return (
            <tr class={`activity-row ${isOptionActivity(r) ? 'option-row' : ''}`}>
              <td class="ticker" data-label="Ticker">
                <span>{r.ticker ?? r.key}</span>
                <span class="activity-chip">activity</span>
              </td>
              <td class="issuer" data-label="Name">{r.name}</td>
              <td class="muted" data-label="Sector">{r.sector} / {r.industry}</td>
              <td class="muted" data-label="Themes"><ThemeLinks labels={broad} /></td>
              <td class="muted granular" data-label="Granular"><ThemeLinks labels={granular} /></td>
              <td class="activity-stack" data-label="Price / value" title="Quarter-end price: reported fair value divided by reported shares.">
                <div class="leg buy">
                  <span class="leg-label">Bought</span>
                  <span class="leg-price num">{prices.buy}</span>
                  <span class="leg-value num">{formatUSD(r.current_value)}</span>
                </div>
                <div class="leg sell">
                  <span class="leg-label">Sold</span>
                  <span class="leg-price num">{prices.sell}</span>
                  <span class="leg-value num">{formatUSD(r.prior_value)}</span>
                </div>
              </td>
              <td class={`num gain ${gain.tone}`} data-label="Since q-end">
                {gain.text}
              </td>
              <td class={`num delta ${r.net_delta_value >= 0 ? 'delta-pos' : 'delta-neg'}`} data-label="Net">
                {signedUSD(r.net_delta_value)}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>
)}

<style>
  .movement {
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    margin-bottom: 14px;
    overflow: hidden;
    background: var(--bg-elev);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.14);
  }
  header {
    padding: 10px 14px;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    display: flex;
    justify-content: space-between;
    text-transform: uppercase;
    letter-spacing: 0.75px;
    background: var(--bg-tinted);
    border-bottom: 1px solid var(--border);
  }
  .status-label { color: var(--accent); }
  header .net {
    color: var(--fg-muted);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--font-mono);
  }
  .header-actions {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
  }
  .csv-button {
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.018);
    color: var(--fg-muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.62rem;
    letter-spacing: 0.7px;
    padding: 2px 7px;
  }
  .csv-button:hover {
    border-color: var(--accent);
    color: var(--accent-hover);
  }
  table { width: 100%; border-collapse: collapse; font-size: 0.825rem; }
  th {
    text-align: left;
    padding: 8px 14px;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    color: var(--fg-dim);
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.016);
  }
  th.num { text-align: right; }
  tr { border-bottom: 1px solid var(--border); }
  tr:last-child { border-bottom: none; }
  tr:hover { background: rgba(255, 255, 255, 0.024); }
  tr.option-row { background: rgba(201, 154, 73, 0.035); }
  tr.option-row:hover { background: rgba(201, 154, 73, 0.06); }
  td { padding: 8px 14px; color: var(--fg); }
  td:last-child, th:last-child { padding-right: 26px; }
  td.num { text-align: right; font-family: var(--font-mono); }
  td.muted { color: var(--fg-muted); font-size: 0.8rem; }
  td.ticker {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--fg);
    vertical-align: top;
  }
  .ticker span { display: block; }
  .activity-chip {
    color: var(--accent);
    font-size: 0.62rem;
    font-weight: 500;
    margin-top: 2px;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }
  .issuer { vertical-align: top; }
  .activity-stack {
    min-width: 190px;
    padding-top: 7px;
    padding-bottom: 7px;
  }
  .leg {
    display: grid;
    grid-template-columns: 58px minmax(64px, 1fr) minmax(60px, 1fr);
    gap: 10px;
    align-items: baseline;
    line-height: 1.35;
  }
  .leg + .leg {
    margin-top: 4px;
    padding-top: 4px;
    border-top: 1px solid var(--border);
  }
  .leg-label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }
  .leg.buy .leg-label { color: var(--buy); }
  .leg.sell .leg-label { color: var(--sell); }
  .leg-price { color: var(--fg); }
  .leg-value { color: var(--fg-muted); text-align: right; }
  td.gain {
    white-space: nowrap;
    font-size: 0.78rem;
    font-family: var(--font-mono);
  }
  td.gain.muted { color: var(--fg-dim); }
  td.gain.pos { color: var(--pos); }
  td.gain.neg { color: var(--neg); }
  td.delta { font-weight: 600; }
  .pos, td.delta-pos { color: var(--pos); }
  .neg, td.delta-neg { color: var(--neg); }

  @media (max-width: 700px) {
    header {
      flex-direction: column;
      gap: 4px;
    }
    .header-actions {
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
    }
    table, tbody { display: block; }
    thead { display: none; }
    tr {
      display: grid;
      grid-template-columns: 1fr;
      gap: 4px;
      padding: 12px 14px;
    }
    td {
      display: grid;
      grid-template-columns: 92px 1fr;
      gap: 10px;
      padding: 0;
      border: 0;
      text-align: left;
    }
    td::before {
      content: attr(data-label);
      color: var(--fg-dim);
      font-family: var(--font-sans);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.7px;
      text-transform: uppercase;
    }
    td.num { text-align: left; }
    td.ticker {
      display: block;
      font-size: 0.95rem;
      margin-bottom: 2px;
    }
    td.ticker::before { content: ''; display: none; }
    .activity-stack { min-width: 0; }
    .leg { grid-template-columns: 54px 1fr; }
    .leg-value { display: none; }
  }
</style>

<script>
  if (!window.__csvDownloadsBound) {
    window.__csvDownloadsBound = true;
    document.addEventListener('click', (event) => {
      const button = event.target.closest('[data-csv]');
      if (!button) return;
      const csv = button.getAttribute('data-csv') || '';
      const filename = button.getAttribute('data-filename') || '13f-changes.csv';
      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    });
  }
</script>
