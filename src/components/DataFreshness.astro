---
import { formatPeriod } from '../lib/format';
import type { PriceSnapshotFile, QuarterEntry } from '../../scripts/types';

interface Props {
  quarter: QuarterEntry;
  prices: PriceSnapshotFile | null;
}

const { quarter, prices } = Astro.props;
const quoteDates = prices
  ? Object.values(prices.records).map(record => record.as_of).sort()
  : [];
const latestQuoteDate = quoteDates.at(-1) ?? prices?.fetched_at ?? null;

function shortDate(value: string | null): string {
  if (!value) return 'n/a';
  const date = /^\d{4}-\d{2}-\d{2}$/.test(value)
    ? new Date(`${value}T12:00:00`)
    : new Date(value);
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---
<aside class="freshness-strip" aria-label="Data freshness">
  <span><strong>Filing</strong> {formatPeriod(quarter.period)} filed {shortDate(quarter.filing_date)}</span>
  <span><strong>Prices</strong> refreshed {shortDate(latestQuoteDate)}</span>
  <span><strong>Themes</strong> editorial review</span>
</aside>

<style>
  .freshness-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    margin: -12px 0 24px;
    padding: 9px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    color: var(--fg-muted);
    font-size: 0.75rem;
  }
  .freshness-strip strong {
    color: var(--accent-soft);
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.7px;
    margin-right: 4px;
    text-transform: uppercase;
  }
</style>
