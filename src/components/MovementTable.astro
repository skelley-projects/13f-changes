---
import { formatUSD, formatPct, formatPrice } from '../lib/format';
import {
  estimateLatestGain,
  estimateUnderlyingMove,
  impliedPositionPrice,
  priceRangeFor,
  priceUnsupportedLabel,
} from '../lib/implied-price';
import ThemeLinks from './ThemeLinks.astro';
import { themeLabelsFor } from '../lib/theme';
import type { MovementRow, PriceSnapshotFile, TaxonomyEntry } from '../../scripts/types';

interface Props {
  status: 'NEW' | 'INCREASED' | 'DECREASED' | 'CLOSED';
  rows: MovementRow[];
  taxonomy: TaxonomyEntry[];
  prices: PriceSnapshotFile | null;
  currentPeriod: string;
}
const { status, rows, taxonomy, prices, currentPeriod } = Astro.props;
const displayRows = [...rows].sort((a, b) => Number(Boolean(a.put_call)) - Number(Boolean(b.put_call)));
const ROW_LIMIT = 120;
const visibleRows = displayRows.slice(0, ROW_LIMIT);
const hiddenCount = Math.max(0, displayRows.length - visibleRows.length);

const styles = {
  NEW: { tone: 'pos', label: 'NEW POSITIONS' },
  INCREASED: { tone: 'pos', label: 'INCREASED' },
  DECREASED: { tone: 'neg', label: 'DECREASED' },
  CLOSED: { tone: 'neg', label: 'CLOSED' },
}[status];

const totalDelta = rows.reduce((s, r) => s + r.delta_value, 0);
const summaryText =
  status === 'NEW' ? `+${formatUSD(totalDelta)} deployed` :
  status === 'CLOSED' ? `${formatUSD(Math.abs(totalDelta))} prior value exited` :
  status === 'INCREASED' ? `${signedUSD(totalDelta)} value change on added shares` :
  `${signedUSD(totalDelta)} value change on trimmed shares`;

function signedUSD(value: number): string {
  return `${value >= 0 ? '+' : '-'}${formatUSD(Math.abs(value))}`;
}

function csvCell(value: string | number | null | undefined): string {
  const text = value === null || value === undefined ? '' : String(value);
  return `"${text.replace(/"/g, '""')}"`;
}

function priceText(row: MovementRow): string {
  const unsupported = priceUnsupportedLabel(row);
  if (unsupported) return unsupported;
  const current = impliedPositionPrice(row, 'current');
  const prior = impliedPositionPrice(row, 'prior');
  if (status === 'NEW') return current === null ? '-' : formatPrice(current);
  if (status === 'CLOSED') {
    const range = priceRangeFor(row, currentPeriod, prices);
    if (range) return `${formatPrice(range.low)}-${formatPrice(range.high)}`;
    return prior === null ? '-' : formatPrice(prior);
  }
  if (current === null || prior === null) return '-';
  return `${formatPrice(prior)} -> ${formatPrice(current)}`;
}

function gainText(row: MovementRow): { text: string; tone: 'pos' | 'neg' | 'muted' } {
  if (status === 'CLOSED') return { text: '-', tone: 'muted' };
  if (row.put_call) {
    const move = estimateUnderlyingMove(row, prices);
    if (!move) return { text: 'underlying n/a', tone: 'muted' };
    return {
      text: `underlying ${move.pct >= 0 ? '+' : ''}${formatPct(move.pct)}`,
      tone: move.pct >= 0 ? 'pos' : 'neg',
    };
  }
  if (priceUnsupportedLabel(row)) return { text: 'n/a', tone: 'muted' };
  const gain = estimateLatestGain(row, prices);
  if (!gain) return { text: '-', tone: 'muted' };
  return {
    text: `${gain.value >= 0 ? '+' : '-'}${formatUSD(Math.abs(gain.value))} (${gain.pct >= 0 ? '+' : ''}${formatPct(gain.pct)})`,
    tone: gain.value >= 0 ? 'pos' : 'neg',
  };
}

const csvRows = [
  ['Ticker', 'Name', 'Sector', 'Industry', 'Themes', 'Granular', 'Price', 'Since q-end', 'Size', 'Change', 'Instrument'],
  ...displayRows.map((row) => {
    const gain = gainText(row);
    return [
      row.ticker ?? row.cusip,
      row.name,
      row.sector,
      row.industry,
      themeLabelsFor(row.tags, taxonomy).join(' | '),
      themeLabelsFor(row.tags, taxonomy, true).join(' | '),
      priceText(row),
      gain.text,
      status === 'NEW' ? (row.current_value === null ? '' : row.current_value) :
        status === 'CLOSED' ? (row.prior_value === null ? '' : row.prior_value) :
        row.delta_pct ?? '',
      status === 'NEW' ? 'NEW' :
        status === 'CLOSED' ? 'CLOSED' :
        row.delta_value,
      row.put_call ?? row.shares_type,
    ];
  }),
];
const csvText = csvRows.map(row => row.map(csvCell).join(',')).join('\n');
const csvFilename = `${currentPeriod}-${status.toLowerCase()}-positions.csv`;
---
{rows.length === 0 ? null : (
  <section class={`movement movement-${styles.tone}`}>
    <header>
      <span class="status-label">{styles.label} ({rows.length})</span>
      <span class="header-actions">
        <button type="button" class="csv-button" data-filename={csvFilename} data-csv={csvText}>CSV</button>
        <span class="net">{summaryText}</span>
      </span>
    </header>
    {status === 'CLOSED' && (
      <p class="table-note">
        Closed value is the prior quarter-end reported stake value, not realized sale proceeds or fund P/L.
      </p>
    )}
    {hiddenCount > 0 && (
      <p class="table-note">
        Showing the largest {ROW_LIMIT} of {displayRows.length} rows by reported value change. CSV export includes the full table.
      </p>
    )}
    <table>
      <thead>
        <tr>
          <th>Ticker</th>
          <th>Name</th>
          <th>Sector</th>
          <th>Themes</th>
          <th class="granular">Granular</th>
          <th class="num price">Price*</th>
          <th class="num gain-head">Since q-end*</th>
          <th class="num">Size</th>
          <th class="num">Change</th>
        </tr>
      </thead>
      <tbody>
        {visibleRows.map((r) => {
          const broad = themeLabelsFor(r.tags, taxonomy);
          const granular = themeLabelsFor(r.tags, taxonomy, true);
          const valueTone = (status === 'INCREASED' || status === 'DECREASED')
            ? (r.delta_value >= 0 ? 'pos' : 'neg')
            : styles.tone;
          const gain = gainText(r);
          return (
            <tr class={r.put_call ? 'option-row' : ''}>
              <td class="ticker" data-label="Ticker">{r.ticker ?? r.cusip}</td>
              <td data-label="Name">{r.name}</td>
              <td class="muted" data-label="Sector">{r.sector} / {r.industry}</td>
              <td class="muted" data-label="Themes"><ThemeLinks labels={broad} /></td>
              <td class="muted granular" data-label="Granular"><ThemeLinks labels={granular} /></td>
              <td class="num muted price" data-label="Price" title="Quarter-end price: reported fair value divided by reported shares.">
                {priceText(r)}
              </td>
              <td class={`num gain ${gain.tone}`} data-label="Since q-end">{gain.text}</td>
              <td class="num muted" data-label="Size">
                {status === 'NEW' && r.current_value !== null && formatUSD(r.current_value)}
                {status === 'CLOSED' && r.prior_value !== null && `was ${formatUSD(r.prior_value)}`}
                {(status === 'INCREASED' || status === 'DECREASED') && r.delta_pct !== null &&
                  `${r.delta_pct > 0 ? '+' : ''}${formatPct(r.delta_pct)}`}
              </td>
              <td class={`num delta delta-${valueTone}`} data-label="Change">
                {status === 'NEW' && 'NEW'}
                {status === 'CLOSED' && 'CLOSED'}
                {(status === 'INCREASED' || status === 'DECREASED') && signedUSD(r.delta_value)}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>
)}

<style>
  .movement {
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: 14px;
    overflow: hidden;
    background: var(--bg-elev);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.14);
  }
  .movement-pos { border-left: 3px solid var(--pos); }
  .movement-neg { border-left: 3px solid var(--neg); }
  header {
    padding: 10px 14px;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    display: flex;
    justify-content: space-between;
    text-transform: uppercase;
    letter-spacing: 0.75px;
    background: var(--bg-tinted);
    border-bottom: 1px solid var(--border);
  }
  .movement-pos .status-label { color: var(--pos); }
  .movement-neg .status-label { color: var(--neg); }
  header .net {
    color: var(--fg-muted);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--font-mono);
  }
  .header-actions {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
  }
  .csv-button {
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.018);
    color: var(--fg-muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.62rem;
    letter-spacing: 0.7px;
    padding: 2px 7px;
  }
  .csv-button:hover {
    border-color: var(--accent);
    color: var(--accent-hover);
  }
  .table-note {
    margin: 0;
    padding: 8px 14px;
    color: var(--fg-muted);
    border-bottom: 1px solid var(--border);
    background: rgba(201, 154, 73, 0.035);
    font-size: 0.74rem;
    line-height: 1.45;
  }
  table { width: 100%; border-collapse: collapse; font-size: 0.825rem; }
  th {
    text-align: left;
    padding: 8px 14px;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    color: var(--fg-dim);
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.016);
  }
  th.num { text-align: right; }
  tr { border-bottom: 1px solid var(--border); }
  tr:last-child { border-bottom: none; }
  tr:hover { background: rgba(255, 255, 255, 0.024); }
  tr.option-row { background: rgba(201, 154, 73, 0.035); }
  tr.option-row:hover { background: rgba(201, 154, 73, 0.06); }
  td { padding: 8px 14px; color: var(--fg); }
  td:last-child, th:last-child { padding-right: 26px; }
  td.num { text-align: right; font-family: var(--font-mono); }
  td.muted { color: var(--fg-muted); font-size: 0.8rem; }
  td.ticker { font-family: var(--font-mono); font-weight: 600; color: var(--fg); }
  td.price { white-space: nowrap; }
  td.gain {
    white-space: nowrap;
    font-size: 0.78rem;
    font-family: var(--font-mono);
  }
  td.gain.muted { color: var(--fg-dim); }
  td.gain.pos { color: var(--pos); }
  td.gain.neg { color: var(--neg); }
  td.delta { font-weight: 600; }
  td.delta-pos { color: var(--pos); }
  td.delta-neg { color: var(--neg); }

  @media (max-width: 700px) {
    table, tbody { display: block; }
    thead { display: none; }
    tr {
      display: grid;
      grid-template-columns: 1fr;
      gap: 4px;
      padding: 12px 14px;
    }
    header {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }
    .header-actions {
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
    }
    td {
      display: grid;
      grid-template-columns: 92px 1fr;
      gap: 10px;
      padding: 0;
      border: 0;
      text-align: left;
    }
    td::before {
      content: attr(data-label);
      color: var(--fg-dim);
      font-family: var(--font-sans);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.7px;
      text-transform: uppercase;
    }
    td.num { text-align: left; }
    td.ticker {
      display: block;
      font-size: 0.95rem;
      margin-bottom: 2px;
    }
    td.ticker::before { content: ''; display: none; }
  }
</style>

<script>
  if (!window.__csvDownloadsBound) {
    window.__csvDownloadsBound = true;
    document.addEventListener('click', (event) => {
      const button = event.target.closest('[data-csv]');
      if (!button) return;
      const csv = button.getAttribute('data-csv') || '';
      const filename = button.getAttribute('data-filename') || '13f-changes.csv';
      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    });
  }
</script>
