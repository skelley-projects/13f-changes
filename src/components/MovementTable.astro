---
import { formatUSD, formatPct, formatPrice } from '../lib/format';
import { estimateLatestGain, impliedPositionPrice } from '../lib/implied-price';
import type { MovementRow, PriceSnapshotFile, TaxonomyEntry } from '../../scripts/types';

interface Props {
  status: 'NEW' | 'INCREASED' | 'DECREASED' | 'CLOSED';
  rows: MovementRow[];
  taxonomy: TaxonomyEntry[];
  prices: PriceSnapshotFile | null;
}
const { status, rows, taxonomy, prices } = Astro.props;

const tagById = new Map(taxonomy.map(t => [t.id, t]));

function broadLabelsFor(tagIds: string[]): string[] {
  const labels = new Set<string>();
  for (const id of tagIds) {
    const entry = tagById.get(id);
    if (!entry) continue;
    const broadId = entry.parent ?? entry.id;
    const broadEntry = tagById.get(broadId);
    if (broadEntry) labels.add(broadEntry.label);
  }
  return Array.from(labels);
}

function granularLabelsFor(tagIds: string[]): string[] {
  const labels: string[] = [];
  for (const id of tagIds) {
    const entry = tagById.get(id);
    if (entry?.parent !== undefined) labels.push(entry.label);
  }
  return labels;
}

const styles = {
  NEW: { tone: 'pos', label: 'NEW POSITIONS' },
  INCREASED: { tone: 'pos', label: 'INCREASED' },
  DECREASED: { tone: 'neg', label: 'DECREASED' },
  CLOSED: { tone: 'neg', label: 'CLOSED' },
}[status];

const totalDelta = rows.reduce((s, r) => s + r.delta_value, 0);
const summaryText =
  status === 'NEW' ? `+${formatUSD(totalDelta)} deployed` :
  status === 'CLOSED' ? `${formatUSD(Math.abs(totalDelta))} exited` :
  status === 'INCREASED' ? `${signedUSD(totalDelta)} value change on added shares` :
  `${signedUSD(totalDelta)} value change on trimmed shares`;

function signedUSD(value: number): string {
  return `${value >= 0 ? '+' : '-'}${formatUSD(Math.abs(value))}`;
}

function priceText(row: MovementRow): string {
  const current = impliedPositionPrice(row, 'current');
  const prior = impliedPositionPrice(row, 'prior');
  if (status === 'NEW') return current === null ? '-' : formatPrice(current);
  if (status === 'CLOSED') return prior === null ? '-' : formatPrice(prior);
  if (current === null || prior === null) return '-';
  return `${formatPrice(prior)} -> ${formatPrice(current)}`;
}

function gainText(row: MovementRow): { text: string; tone: 'pos' | 'neg' | 'muted' } {
  if (status === 'CLOSED') return { text: '-', tone: 'muted' };
  const gain = estimateLatestGain(row, prices);
  if (!gain) return { text: '-', tone: 'muted' };
  return {
    text: `${gain.value >= 0 ? '+' : '-'}${formatUSD(Math.abs(gain.value))} (${gain.pct >= 0 ? '+' : ''}${formatPct(gain.pct)})`,
    tone: gain.value >= 0 ? 'pos' : 'neg',
  };
}
---
{rows.length === 0 ? null : (
  <section class={`movement movement-${styles.tone}`}>
    <header>
      <span class="status-label">{styles.label} ({rows.length})</span>
      <span class="net">{summaryText}</span>
    </header>
    <table>
      <thead>
        <tr>
          <th>Ticker</th>
          <th>Name</th>
          <th>Sector</th>
          <th>Themes</th>
          <th class="granular">Granular</th>
          <th class="num price">Price*</th>
          <th class="num gain-head">Est. gain</th>
          <th class="num">Size</th>
          <th class="num">Change</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => {
          const broad = broadLabelsFor(r.tags);
          const granular = granularLabelsFor(r.tags);
          const valueTone = (status === 'INCREASED' || status === 'DECREASED')
            ? (r.delta_value >= 0 ? 'pos' : 'neg')
            : styles.tone;
          const gain = gainText(r);
          return (
            <tr>
              <td class="ticker">{r.ticker ?? r.cusip}</td>
              <td>{r.name}</td>
              <td class="muted">{r.sector} / {r.industry}</td>
              <td class="muted">{broad.length === 0 ? '-' : broad.join(', ')}</td>
              <td class="muted granular">{granular.length === 0 ? '-' : granular.join(', ')}</td>
              <td class="num muted price" title="Quarter-end price: reported fair value divided by reported shares.">
                {priceText(r)}
              </td>
              <td class={`num gain ${gain.tone}`}>{gain.text}</td>
              <td class="num muted">
                {status === 'NEW' && r.current_value !== null && formatUSD(r.current_value)}
                {status === 'CLOSED' && r.prior_value !== null && `was ${formatUSD(r.prior_value)}`}
                {(status === 'INCREASED' || status === 'DECREASED') && r.delta_pct !== null &&
                  `${r.delta_pct > 0 ? '+' : ''}${formatPct(r.delta_pct)}`}
              </td>
              <td class={`num delta delta-${valueTone}`}>
                {status === 'NEW' && 'NEW'}
                {status === 'CLOSED' && 'CLOSED'}
                {(status === 'INCREASED' || status === 'DECREASED') && signedUSD(r.delta_value)}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>
)}

<style>
  .movement {
    border: 1px solid var(--border);
    border-radius: 8px;
    margin-bottom: 14px;
    overflow: hidden;
    background: var(--bg-elev);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }
  .movement-pos { border-left: 3px solid var(--pos); }
  .movement-neg { border-left: 3px solid var(--neg); }
  header {
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    display: flex;
    justify-content: space-between;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: var(--bg-tinted);
    border-bottom: 1px solid var(--border);
  }
  .movement-pos .status-label { color: var(--pos); }
  .movement-neg .status-label { color: var(--neg); }
  header .net {
    color: var(--fg-muted);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--font-mono);
  }
  table { width: 100%; border-collapse: collapse; font-size: 0.825rem; }
  th {
    text-align: left;
    padding: 7px 12px;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.55px;
    color: var(--fg-dim);
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.012);
  }
  th.num { text-align: right; }
  tr { border-bottom: 1px solid var(--border); }
  tr:last-child { border-bottom: none; }
  tr:hover { background: var(--bg-tinted); }
  td { padding: 6px 12px; color: var(--fg); }
  td.num { text-align: right; font-family: var(--font-mono); }
  td.muted { color: var(--fg-muted); font-size: 0.8rem; }
  td.ticker { font-family: var(--font-mono); font-weight: 600; color: var(--fg); }
  td.price { white-space: nowrap; }
  td.gain {
    white-space: nowrap;
    font-size: 0.78rem;
    font-family: var(--font-mono);
  }
  td.gain.muted { color: var(--fg-dim); }
  td.gain.pos { color: var(--pos); }
  td.gain.neg { color: var(--neg); }
  td.delta { font-weight: 600; }
  td.delta-pos { color: var(--pos); }
  td.delta-neg { color: var(--neg); }

  @media (max-width: 700px) {
    th.gain-head { display: none; }
    td.gain { display: none; }
    td.price { display: none; }
    th.price { display: none; }
    th.granular { display: none; }
    td.granular { display: none; }
  }
</style>
