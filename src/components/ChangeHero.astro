---
import { formatUSD } from '../lib/format';
import type { DiffFile } from '../../scripts/types';

interface Props {
  diff: DiffFile;
  summary: string;
}
const { diff, summary } = Astro.props;
const m = diff.movements;
const netFlow = diff.totals.net_flow;
const activityCount = m.activity?.length ?? 0;
const flowSign = netFlow >= 0 ? '+' : '-';
---
{diff.prior_period === null ? (
  <section class="hero first-filing">
    <p class="banner">First filing on record &mdash; no prior-quarter comparison available yet.</p>
  </section>
) : (
  <section class="hero">
    <div class="label">What changed this quarter</div>
    <p class="summary">{summary}</p>
    <div class="counts">
      <span><strong class="up">+{m.new.length}</strong> new</span>
      <span><strong class="down">&minus;{m.closed.length}</strong> closed</span>
      {activityCount > 0 && (
        <span><strong class="activity">&harr;{activityCount}</strong> activity</span>
      )}
      <span><strong class="up">&uarr;{m.increased.length}</strong> increased</span>
      <span><strong class="down">&darr;{m.decreased.length}</strong> decreased</span>
      <span class="muted">| {m.unchanged_count} unchanged</span>
      <span class="net">reported 13F value change <span class={netFlow >= 0 ? 'up' : 'down'}>{flowSign}{formatUSD(Math.abs(netFlow))}</span></span>
    </div>
  </section>
)}

<style>
  .hero {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0)), var(--bg-elev);
    border: 1px solid var(--border);
    border-top: 3px solid var(--accent);
    padding: 22px 24px;
    margin-bottom: 28px;
    border-radius: 6px;
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.18);
  }
  .first-filing {
    background: var(--bg-elev);
    border-top-color: var(--fg-dim);
  }
  .label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.75px;
    margin-bottom: 8px;
  }
  .summary {
    font-family: var(--font-serif);
    font-size: 1.24rem;
    line-height: 1.52;
    margin: 0 0 16px;
    color: var(--fg);
  }
  .banner { color: var(--fg-muted); margin: 0; }
  .counts {
    display: flex;
    gap: 10px 18px;
    font-size: 0.82rem;
    color: var(--fg-muted);
    flex-wrap: wrap;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }
  .counts strong { font-family: var(--font-mono); }
  .up { color: var(--pos); }
  .down { color: var(--neg); }
  .activity { color: var(--accent); }
  .muted { color: var(--fg-muted); }
  .net { font-weight: 600; font-family: var(--font-mono); }
</style>
